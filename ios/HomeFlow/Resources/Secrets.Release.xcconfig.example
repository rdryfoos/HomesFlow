// Cloud Supabase credentials for Release builds (TestFlight, device demos).
// 1. Copy this file to Secrets.Release.xcconfig (gitignored)
// 2. Fill in values from Supabase Dashboard → Project Settings → API

SUPABASE_URL = https:/$()/YOUR_PROJECT_REF.supabase.co
SUPABASE_ANON_KEY = your-cloud-anon-or-publishable-key-here
SENTRY_DSN = your-sentry-dsn-here
