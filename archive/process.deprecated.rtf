\ls12\ilvl0
\f0\b0 \cf0 {\listtext	\'95	}\uc0\u9679 	Implements the approved Technical Plans.\
{\listtext	\'95	}\uc0\u9679 	If behavior diverges from the Specification, Glossary, or Constitution, the code is considered incorrect until reconciled.\
\pard\pardeftab720\ri0\sb320\sa200\partightenfactor0
